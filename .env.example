PORT=3000
DATABASE_URL=postgresql://localhost:5432/eyy
GIPHY_API_KEY=your_giphy_api_key

# Public base URL of this service. Required in production.
# Used to build the Google Chat dialog submit URL.
PUBLIC_BASE_URL=https://your-domain

# Required in production — the endpoint URL used as token audience for Google Chat verification.
GOOGLE_CHAT_AUDIENCE=https://your-domain/google-chat

# Slack — set both to enable the Slack endpoints. Leave unset to run Google-Chat-only.
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Set to "development" to skip token / signature verification locally.
NODE_ENV=development
